# Resolve the repo root (works whether run as `bash mainmenu`
# or `bash <(curl ...)` from inside the cloned folder)
_find_repo_root() {
    local dir
    dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)"
    # Walk up looking for .git or just use current dir
    while [[ "$dir" != "/" ]]; do
        [[ -d "$dir/.git" ]] && { echo "$dir"; return; }
        dir="$(dirname "$dir")"
    done
    # Fallback: use the directory the script lives in
    echo "$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)"
}

