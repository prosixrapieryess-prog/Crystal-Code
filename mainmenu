N=$'\033[0m'         # Reset

# ══════════════════════════════════════════════
#   SPINNER ANIMATION
# ══════════════════════════════════════════════
spinner() {
    local msg="$1"
    local pid=$!
    local frames=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${P}${frames[$i]}${N}  ${W}%s${N}" "$msg"
        i=$(( (i+1) % ${#frames[@]} ))
        sleep 0.08
    done
    printf "\r  ${G}✔${N}  ${W}%s${N}\n" "$msg"
}

# ══════════════════════════════════════════════
#   TYPEWRITER EFFECT
# ══════════════════════════════════════════════
typewriter() {
    local text="$1"
    local color="${2:-$W}"
    local delay=0.018
    printf "%s" "$color"
    for ((i=0; i<${#text}; i++)); do
        printf "%s" "${text:$i:1}"
        sleep $delay
    done
    printf "%s\n" "$N"
}

# ══════════════════════════════════════════════
#   GLITCH EFFECT (fast flicker on text)
# ══════════════════════════════════════════════
glitch_text() {
    local text="$1"
    local chars='@#$%&!?*'
    local len=${#text}
    for run in 1 2 3; do
        local out=""
        for ((i=0; i<len; i++)); do
            if (( RANDOM % 4 == 0 )); then
                out+="${chars:$((RANDOM % ${#chars})):1}"
            else
                out+="${text:$i:1}"
            fi
        done
        printf "\r  ${P}%s${N}" "$out"
        sleep 0.07
    done
    printf "\r  ${P}%s${N}\n" "$text"
}

# ══════════════════════════════════════════════
#   FANCY PROGRESS BAR
# ══════════════════════════════════════════════
progress_bar() {
    local label="${1:-Loading}"
    local total=40
    printf "\n  ${C}%s${N}\n" "$label"
    printf "  ${DIM}["
    for ((i=0; i<total; i++)); do printf " "; done
    printf "]${N}"
    printf "  ${DIM}[${N}"
    for ((i=0; i<total; i++)); do
        printf "${G}█${N}"
        sleep 0.04
    done
    printf "${DIM}]${N}  ${G}100%%${N}\n"
}

# ══════════════════════════════════════════════
#   MARQUEE BANNER
# ══════════════════════════════════════════════
marquee() {
    local text="  🔥 ProXLegendYT | Powered by ProXLegendYT NODE | Discord: https://dcserver.link/crystalsmp 🔥  "
    local width=60
    local len=${#text}
    for ((i=0; i<len-width; i++)); do
        printf "\r  ${Y}%.${width}s${N}" "${text:$i}"
        sleep 0.05
    done
    echo ""
}

# ══════════════════════════════════════════════
#   FIREWORKS ANIMATION
# ══════════════════════════════════════════════
fireworks() {
    local shots=('💥' '✨' '🎆' '🎇' '⚡' '🌟' '💫')
    local cols=60
    for i in {1..12}; do
        local col=$(( RANDOM % cols + 4 ))
        local shot="${shots[$((RANDOM % ${#shots[@]}))]}"
        printf "\033[%dG%s\n" "$col" "$shot"
        sleep 0.06
    done
}

