        local px_stat; px_stat=$(get_proxmox_status)
        echo -e "  ${GD}${BD}  1${N}  ${DM}│${N}  🖥️   ${WH}VM / KVM Installer${N}"
        tdiv
        echo -e "  ${GL}${BD}  2${N}  ${DM}│${N}  🚀  ${WH}Deploy Proxmox VE          ${DM}Status: ${N}${px_stat}"
        tdiv
        echo -e "  ${TL}${BD}  3${N}  ${DM}│${N}  📋  ${WH}Show Running Containers${N}"
        tdiv
        echo -e "  ${OR}${BD}  4${N}  ${DM}│${N}  🛑  ${WH}Stop Proxmox Container${N}"
        tdiv
        echo -e "  ${RE}${BD}  5${N}  ${DM}│${N}  🗑️   ${WH}Remove Proxmox Container${N}"
        tdiv
        echo -e "  ${RE}${BD}  0${N}  ${DM}│${N}  ⬅️   ${WH}Back${N}"
        div
        printf "\n  ${GR}${BD}→${N} ${BD}${WH}VPS Command: ${N}"
        read -r vc
 
        case $vc in
            1)
                sub_header; section "🖥️  VM / KVM Installer"
                progress_bar "🔧  Loading KVM installer"
                set +u
                bash <(curl -fsSL https://raw.githubusercontent.com/prosixrapieryess-prog/Crystal-VM-KVM/main/mainmenu)
                set -u
                pause ;;
            2)
                sub_header; section "🚀  Deploying Proxmox VE..."
                progress_bar "📦  Pulling rtedpro/proxmox:9.0.11"
                if docker run -itd \
                      --name proxmoxve --hostname pve --privileged \
                      --cgroupns=host \
                      --security-opt apparmor=unconfined \
                      --security-opt seccomp=unconfined \
                      -v /sys/fs/cgroup:/sys/fs/cgroup:rw \
                      -v /lib/modules:/lib/modules:ro \
                      -v /dev/fuse:/dev/fuse \
                      -v /sys/kernel/debug:/sys/kernel/debug \
                      -p 8006:8006 --restart unless-stopped \
                      rtedpro/proxmox:9.0.11; then
                    echo -e "\n  ${GR}${BD}✅  Proxmox VE launched!  $(get_proxmox_status)${N}"
                    echo -e "  ${CY}   Access → https://YOUR_SERVER_IP:8006${N}"
                    echo -e "  ${DM}   Login: root / (blank password first time)${N}"
                else
                    echo -e "\n  ${RE}❌  Launch failed. Is Docker installed and running?${N}"
                    echo -e "  ${DM}   Install Docker: curl -fsSL https://get.docker.com | sh${N}"
                fi
                pause ;;
            3)
                sub_header; section "📋  Running Containers"
                if command -v docker &>/dev/null; then
                    docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}" \
                        || echo -e "  ${RE}Docker daemon is not running.${N}"
                else
                    echo -e "  ${RE}Docker is not installed.${N}"
                fi
                pause ;;
            4)
                sub_header; section "🛑  Stop Proxmox Container"
                docker stop proxmoxve 2>/dev/null \
                    && echo -e "  ${GR}✔  Container stopped.${N}" \
                    || echo -e "  ${RE}❌  Not found or already stopped.${N}"
                pause ;;
            5)
                sub_header; section "🗑️  Remove Proxmox Container"
                printf "  ${RE}Type 'yes' to confirm removal: ${N}"; read -r conf
                if [[ "$conf" == "yes" ]]; then
                    docker stop proxmoxve 2>/dev/null || true
                    docker rm   proxmoxve 2>/dev/null \
                        && echo -e "  ${GR}✔  Container removed.${N}" \
                        || echo -e "  ${RE}❌  Container not found.${N}"
                else
                    echo -e "  ${CY}Cancelled.${N}"
                fi
                pause ;;
            0) break ;;
            *) echo -e "\n  ${RE}❌  Invalid option.${N}"; sleep 1 ;;
        esac
    done
}
 
