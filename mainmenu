    local -a f=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local -a fc=("${CY}" "${PU}" "${YE}" "${GR}" "${CY}" "${RE}" "${PU}" "${AQ}")
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${fc[$i]}${f[$i]}${N}  ${WH}%s${N}" "$msg"
        i=$(( (i+1) % 8 )); sleep 0.06
    done
    printf "\r  ${GR}${BD}✔${N}  ${WH}%s${N}\n" "$msg"
}
 
