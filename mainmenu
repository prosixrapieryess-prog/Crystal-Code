        echo -e "  ${GD}${BD}  1${N}  ${DM}│${N}  🧩  ${WH}Panels${N}";           tdiv
        echo -e "  ${GL}${BD}  2${N}  ${DM}│${N}  👤  ${WH}Create Admin User${N}"; tdiv
        echo -e "  ${TL}${BD}  3${N}  ${DM}│${N}  🔄  ${WH}Update Panel${N}";      tdiv
        echo -e "  ${OR}${BD}  4${N}  ${DM}│${N}  🔒  ${WH}Install SSL${N}";       tdiv
        echo -e "  ${RE}${BD}  5${N}  ${DM}│${N}  🗑️   ${WH}Uninstall Panel${N}";  tdiv
        echo -e "  ${RE}${BD}  0${N}  ${DM}│${N}  ⬅️   ${WH}Back${N}";             div
        printf "\n  ${GR}${BD}→${N} ${BD}${WH}Panel Command: ${N}"; read -r pc
 
        case $pc in
            1)
                sub_header; section "🧩  Panel Installer"
                progress_bar "📦  Panels installer"
                set +u
                bash <(curl -s https://raw.githubusercontent.com/nobita329/hub/refs/heads/main/Codinghub/panel/run.sh)
                set -u
                pause ;;
            2)
                sub_header; section "👤  Create Panel User"
                if [[ -d /var/www/pterodactyl ]]; then
                    cd /var/www/pterodactyl || { echo -e "  ${RE}❌  Cannot enter panel directory!${N}"; pause; continue; }
                    php artisan p:user:make
                else
                    echo -e "  ${RE}❌  Panel is not installed!${N}"
                fi
                pause ;;
            3)
                sub_header; section "🔄  Updating Panel..."
                if [[ ! -d /var/www/pterodactyl ]]; then
                    echo -e "  ${RE}❌  Panel not found — install it first!${N}"
                    pause; continue
                fi
                progress_bar "⬇️  Downloading latest release"
                cd /var/www/pterodactyl || { echo -e "  ${RE}❌  Failed to enter panel directory!${N}"; pause; continue; }
                php artisan down
                if ! curl -fsSL -o panel.tar.gz \
                        https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz; then
                    echo -e "  ${RE}❌  Download failed! Check your internet connection.${N}"
                    php artisan up 2>/dev/null || true
                    pause; continue
                fi
                if ! tar -xzf panel.tar.gz; then
                    echo -e "  ${RE}❌  Archive extraction failed!${N}"
                    php artisan up 2>/dev/null || true
                    pause; continue
                fi
                rm -f panel.tar.gz
                COMPOSER_ALLOW_SUPERUSER=1 composer install --no-dev --optimize-autoloader
                php artisan migrate --seed --force && php artisan up
                echo -e "\n  ${GR}${BD}✔  Panel updated successfully!${N}"
                pause ;;
            4)
                sub_header; section "🔒  SSL Certificate"
                set +u
                bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/ssl.sh)
                set -u
                pause ;;
            5)
                sub_header; section "🗑️  Uninstall Panel"
                echo -e "  ${RE}${BD}⚠️  This will permanently delete the panel!${N}"
                printf "  ${RE}Type 'yes' to confirm: ${N}"; read -r conf
                if [[ "$conf" == "yes" ]]; then
                    progress_bar "🗑️  Removing panel"
                    rm -rf /var/www/pterodactyl
                    echo -e "  ${GR}✔  Panel removed.${N}"
                else
                    echo -e "  ${CY}Cancelled.${N}"
                fi
                sleep 2 ;;
            0) break ;;
            *) echo -e "\n  ${RE}❌  Invalid option.${N}"; sleep 1 ;;
        esac
    done
}
 
# ══════════════════════════════════════════════════════════════
#  [6]  CLOUDFLARE
# ══════════════════════════════════════════════════════════════
cloudflare_menu() {
    cf_header() {
        sub_header
        local arch svc_txt pid_txt up_txt
        arch=$(dpkg --print-architecture 2>/dev/null || uname -m)
        svc_txt="${DM}NOT INSTALLED${N}"
        pid_txt="${DM}---${N}"
        up_txt="${DM}---${N}"
 
        if command -v cloudflared &>/dev/null; then
            if systemctl is-active --quiet cloudflared 2>/dev/null; then
                svc_txt="${GR}${BD}ACTIVE ● RUNNING${N}"
                pid_txt="${WH}$(pgrep -x cloudflared 2>/dev/null | head -1 || echo '---')${N}"
                local raw_ts
                raw_ts=$(systemctl show -p ActiveEnterTimestamp cloudflared 2>/dev/null)
                up_txt="${CY}${raw_ts#ActiveEnterTimestamp=}${N}"
            else
                svc_txt="${RE}${BD}INACTIVE ○ STOPPED${N}"
            fi
        fi
 
        echo -e "  ${R7}${BD}┌────────────────────────────────────────────────┐${N}"
        echo -e "  ${R7}${BD}│${N}  ${R7}${BD}☁️   CLOUDFLARE TUNNEL MANAGER${N}             ${R7}${BD}│${N}"
        echo -e "  ${R7}${BD}└────────────────────────────────────────────────┘${N}"
        echo -e "\n  ${DM}🖥  Arch    :${N} ${WH}${arch}${N}"
        echo -e "  ${DM}🔴  Status  :${N} ${svc_txt}"
        echo -e "  ${DM}🔢  PID     :${N} ${pid_txt}"
        echo -e "  ${DM}⏱  Uptime  :${N} ${up_txt}"
        div; echo ""
    }
 
    cf_install() {
        cf_header; section "⚡  INSTALL / UPDATE TUNNEL"
 
        echo -e "  ${R1}${BD}[1/4]${N} Configuring Cloudflare APT repo..."
        (
            sudo mkdir -p --mode=0755 /usr/share/keyrings
            curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg \
                | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null
            echo 'deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared any main' \
                | sudo tee /etc/apt/sources.list.d/cloudflared.list >/dev/null
        ) &
        spinner "Configuring APT repo"
 
        echo -e "\n  ${R4}${BD}[2/4]${N} Installing cloudflared binary..."
        (sudo apt-get update -qq >/dev/null && sudo apt-get install -y cloudflared -qq >/dev/null 2>&1) &
        spinner "Installing cloudflared"
 
        if ! command -v cloudflared &>/dev/null; then
            echo -e "  ${RE}❌  Installation failed!${N}"
            pause; return
        fi
 
        echo -e "\n  ${R6}${BD}[3/4]${N} Removing any old tunnel service..."
        if systemctl list-units --type=service 2>/dev/null | grep -q cloudflared; then
            (sudo cloudflared service uninstall >/dev/null 2>&1) &
            spinner "Cleaning old service"
        else
            echo -e "  ${GR}✔${N}  No existing service found, skipping."
        fi
 
        echo ""
        echo -e "  ${GD}${BD}┌──────────────────────────────────────────────────┐${N}"
        echo -e "  ${GD}${BD}│${N}  ${BD}🔐  Paste your Tunnel Token below${N}               ${GD}${BD}│${N}"
        echo -e "  ${GD}${BD}│${N}  ${DM}(Paste the full 'sudo cloudflared...' command)${N}   ${GD}${BD}│${N}"
        echo -e "  ${GD}${BD}└──────────────────────────────────────────────────┘${N}"
        printf "\n  ${R9}${BD}➤  TOKEN: ${N}"; read -r raw_token
 
        local token
        token=$(echo "$raw_token" \
            | sed 's/sudo cloudflared service install //g;s/cloudflared service install //g' \
            | xargs)
 
        if [[ -z "$token" ]]; then
            echo -e "  ${RE}❌  Token is empty! Aborting.${N}"
            pause; return
        fi
 
        echo -e "\n  ${R8}${BD}[4/4]${N} Registering tunnel service..."
        if sudo cloudflared service install "$token"; then
            progress_bar "🌐  Bringing tunnel online"
            if systemctl is-active --quiet cloudflared 2>/dev/null; then
                echo -e "  ${GR}${BD}✅  Tunnel is ONLINE!${N}"
            else
                echo -e "  ${RE}❌  Service installed but failed to start.${N}"
                echo -e "  ${DM}   Debug: sudo journalctl -u cloudflared -n 50${N}"
            fi
        else
            echo -e "  ${RE}❌  Service installation failed. Check your token.${N}"
        fi
        pause
    }
 
    cf_uninstall() {
        cf_header; section "🗑️  UNINSTALL CLOUDFLARE"
        echo -e "  ${RE}${BD}⚠️  Removes tunnel service, binary and APT repo!${N}"
        printf "\n  ${RE}Type 'yes' to confirm: ${N}"; read -r conf
        if [[ "$conf" == "yes" ]]; then
            (
                sudo cloudflared service uninstall >/dev/null 2>&1 || true
                sudo apt-get remove -y cloudflared -qq >/dev/null 2>&1 || true
                sudo rm -f /etc/apt/sources.list.d/cloudflared.list
                sudo rm -f /usr/share/keyrings/cloudflare-main.gpg
            ) &
            spinner "Removing Cloudflared"
            echo -e "\n  ${GR}✔  Cloudflared fully removed.${N}"
        else
            echo -e "\n  ${CY}Cancelled.${N}"
        fi
        sleep 2
    }
 
    while true; do
        cf_header
        echo -e "  ${GR}${BD}  1${N}  ${DM}│${N}  ☁️   ${WH}Install / Update Tunnel${N}"; tdiv
        echo -e "  ${RE}${BD}  2${N}  ${DM}│${N}  🗑️   ${WH}Uninstall Completely${N}";    tdiv
        echo -e "  ${DM}  0${N}  ${DM}│${N}  ⬅️   ${WH}Back${N}"; div
        printf "\n  ${R9}${BD}root@cloudflare:~# ${N}"; read -r cc
        case $cc in
            1) cf_install ;;
            2) cf_uninstall ;;
            0) break ;;
            *) echo -e "  ${RE}❌  Invalid option.${N}"; sleep 1 ;;
        esac
    done
}
 
