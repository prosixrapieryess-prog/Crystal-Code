        echo -e "  ${DIM}🔴  Service      :${N} $s_status"
        echo -e "  ${DIM}🔢  Process ID   :${N} $s_pid"
        echo -e "  ${DIM}⏱  Last Started :${N} ${C}${s_uptime:-N/A}${N}"
        divider
        echo ""
    }

    cf_install() {
        cf_show_header
        section_header "⚡  CLOUDFLARE INSTALL SEQUENCE"

        echo -e "  ${C}[1/5]${N} ${W}🔑  Configuring Repository...${N}"
        (
            sudo mkdir -p --mode=0755 /usr/share/keyrings
            curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null
            echo 'deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared any main' | sudo tee /etc/apt/sources.list.d/cloudflared.list >/dev/null
        ) &
        spinner "Adding Cloudflare APT repo"

        echo ""
        echo -e "  ${C}[2/5]${N} ${W}📦  Installing Binary...${N}"
        (sudo apt-get update -qq >/dev/null && sudo apt-get install -y cloudflared -qq >/dev/null 2>&1) &
        spinner "Installing cloudflared binary"

        if ! command -v cloudflared &>/dev/null; then
            echo -e "  ${R}❌  Binary installation failed!${N}"
            pause; return
        fi
        echo -e "  ${G}✔   Binary installed.${N}"

        echo ""
        echo -e "  ${C}[3/5]${N} ${W}🧹  Removing Conflicting Services...${N}"
        if systemctl list-units --type=service 2>/dev/null | grep -q cloudflared; then
            (sudo cloudflared service uninstall >/dev/null 2>&1) &
            spinner "Cleaning old services"
        else
            echo -e "  ${DIM}   No existing service found. Skipping.${N}"
        fi

        echo ""
        echo -e "  ${Y}┌────────────────────────────────────────────────────────┐${N}"
        echo -e "  ${Y}│${N}  ${BOLD}🔐  ACTION REQUIRED${N}                                     ${Y}│${N}"
        echo -e "  ${Y}│${N}  Paste your ${C}Tunnel Token${N} below.                         ${Y}│${N}"
        echo -e "  ${Y}│${N}  ${DIM}(You can paste the full 'sudo cloudflared...' cmd)${N}     ${Y}│${N}"
        echo -e "  ${Y}└────────────────────────────────────────────────────────┘${N}"
        echo ""
        printf "  ${P}➤  TOKEN: ${N}"
        read -r USER_TOKEN

        CLEAN_TOKEN=$(echo "$USER_TOKEN" | sed 's/sudo cloudflared service install //g' | sed 's/cloudflared service install //g' | xargs)

        if [[ -z "$CLEAN_TOKEN" ]]; then
            echo -e "  ${R}❌  Token cannot be empty!${N}"; pause; return
        fi

        echo ""
        echo -e "  ${C}[4/5]${N} ${W}🔗  Registering Tunnel Service...${N}"
        sudo cloudflared service install "$CLEAN_TOKEN"

        echo ""
        echo -e "  ${C}[5/5]${N} ${W}⏳  Waiting for service to initialize...${N}"
        progress_bar "  🌐  Bringing tunnel online"

        echo ""
        if systemctl is-active --quiet cloudflared; then
            echo -e "  ${G}${BOLD}✅  SUCCESS: Tunnel is Online & Stable!${N}"
            fireworks
        else
            echo -e "  ${R}${BOLD}❌  ERROR: Service failed to start.${N}"
            echo -e "  ${DIM}   Debug: sudo journalctl -u cloudflared -f${N}"
        fi
        pause
    }

    cf_uninstall() {
        cf_show_header
        section_header "🗑️   CLOUDFLARE UNINSTALL"
        echo -e "  ${R}${BOLD}⚠️   WARNING: This removes the tunnel service & binary!${N}"
        echo ""
        printf "  ${R}➤  Type 'yes' to confirm removal: ${N}"
        read -r confirm
        if [[ "$confirm" =~ ^[Yy][Ee][Ss]$ ]]; then
            echo ""
            (
                sudo cloudflared service uninstall >/dev/null 2>&1
                sudo apt-get remove -y cloudflared -qq >/dev/null 2>&1
                sudo rm -f /etc/apt/sources.list.d/cloudflared.list
                sudo rm -f /usr/share/keyrings/cloudflare-main.gpg
            ) &
            spinner "Removing Cloudflared completely"
            echo -e "\n  ${G}✔   Cloudflared completely removed.${N}"
        else
            echo -e "\n  ${C}ℹ️   Operation cancelled.${N}"
        fi
        sleep 2
    }

    while true; do
        cf_show_header
        echo -e "  ${W}${BOLD}AVAILABLE OPERATIONS:${N}"
        echo ""
        echo -e "  ${G}  1${N}  ${DIM}│${N}  ☁️   ${W}Install / Update Tunnel${N}  ${DIM}(Auto-Fix)${N}"
        thin_div
        echo -e "  ${R}  2${N}  ${DIM}│${N}  🗑️   ${W}Uninstall Completely${N}     ${DIM}(Remove All)${N}"
        thin_div
        echo -e "  ${DIM}  0${N}  ${DIM}│${N}  ⬅️   ${W}Back to Main Menu${N}"
        divider
        echo ""
        printf "  ${P}root@cloudflared:~# ${N}"
        read -r cf_choice

        case $cf_choice in
            1) cf_install ;;
            2) cf_uninstall ;;
            0) break ;;
            *) echo -e "  ${R}❌  Invalid option${N}"; sleep 1 ;;
        esac
    done
}

