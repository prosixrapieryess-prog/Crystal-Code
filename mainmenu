# ── AUTO-TRIGGER: write dev.nix if missing ──────────────────
auto_idx_setup() {
    local repo_root
    repo_root="$(_find_repo_root)"
    local nix_file="$repo_root/.idx/dev.nix"

    if [[ ! -f "$nix_file" ]]; then
        # Show a brief notice (non-blocking)
        echo -e "\n  ${CY}${BD}💎  Crystal-Code.git — First Run Detected${N}"
        echo -e "  ${DM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}"
        echo -e "  ${YE}⚙   Auto-generating${N} ${WH}.idx/dev.nix${N} ${YE}for IDX...${N}"
        write_dev_nix "$repo_root"
        echo -e "  ${GR}${BD}✅  .idx/dev.nix created at:${N} ${WH}$nix_file${N}"
        echo -e "  ${DM}    IDX will install all packages on next open.${N}\n"
        sleep 1
