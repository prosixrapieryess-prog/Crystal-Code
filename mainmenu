ptero_menu() {
    while true; do
        clear
        header

        section_header "🦕  PTERODACTYL CONTROL CENTER v2.1"

        echo -e "  ${C}  1${N}  ${DIM}│${N}  🧩  ${W}Install Panel${N}"
        thin_div
        echo -e "  ${C}  2${N}  ${DIM}│${N}  👤  ${W}Create User${N}"
        thin_div
        echo -e "  ${C}  3${N}  ${DIM}│${N}  🔄  ${W}Update Panel${N}"
        thin_div
        echo -e "  ${C}  4${N}  ${DIM}│${N}  🔒  ${W}Install SSL${N}"
        thin_div
        echo -e "  ${C}  5${N}  ${DIM}│${N}  🗑️   ${W}Uninstall Panel${N}"
        thin_div
        echo -e "  ${R}  0${N}  ${DIM}│${N}  ⬅️   ${W}Back to Main Menu${N}"
        divider
        echo ""
        printf "  ${Y}➤ Select option: ${N}"
        read -r opt

        case $opt in
            1)
                section_header "🧩  Installing Pterodactyl Panel..."
                progress_bar "  📦  Fetching installer"
                bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/install.sh)
                pause
                ;;
            2)
                section_header "👤  Creating Panel User..."
                cd /var/www/pterodactyl 2>/dev/null && php artisan p:user:make
                pause
                ;;
            3)
                section_header "🔄  Updating Pterodactyl Panel..."
                cd /var/www/pterodactyl || { echo -e "  ${R}❌  Panel not installed!${N}"; sleep 2; continue; }
                progress_bar "  📥  Downloading latest release"
                php artisan down
                curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
                tar -xzvf panel.tar.gz
                COMPOSER_ALLOW_SUPERUSER=1 composer install --no-dev --optimize-autoloader
                php artisan migrate --seed --force
                php artisan up
                echo -e "\n  ${G}✔  Panel updated successfully!${N}"
                pause
                ;;
            4)
                section_header "🔒  Installing SSL Certificate..."
                progress_bar "  🔐  Setting up SSL"
                bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/ssl.sh)
                pause
                ;;
            5)
                section_header "🗑️   Uninstalling Pterodactyl Panel"
                echo -e "  ${R}${BOLD}⚠️   WARNING: This will permanently delete the panel!${N}"
                echo ""
                printf "  ${Y}➤ Type 'yes' to confirm: ${N}"
                read -r confirm
                if [[ "$confirm" == "yes" ]]; then
                    progress_bar "  🗑️   Removing files"
                    rm -rf /var/www/pterodactyl
                    echo -e "\n  ${G}✔  Panel removed successfully.${N}"
                else
                    echo -e "\n  ${C}ℹ️   Operation cancelled.${N}"
                fi
                sleep 2
                ;;
            0) break ;;
            *) echo -e "  ${R}❌  Invalid option!${N}"; sleep 1 ;;
        esac
    done
}

# ══════════════════════════════════════════════
#   BLUEPRINT INSTALLER (option 6)
# ══════════════════════════════════════════════
run_blueprint() {
    PT_DIR="/var/www/pterodactyl"

    if [ "$EUID" -ne 0 ]; then
        echo -e "  ${R}❌  Error: Please run as root (sudo bash $0)${N}"
        return
    fi

    clear
    header
    section_header "🔷  BLUEPRINT v3.0 AUTO-INSTALLER & FIXER"

    echo -e "  ${Y}⚠️   Target Directory:${N} ${C}$PT_DIR${N}"
    typewriter "  ⏳  Starting automated sequence in 3 seconds..." "$W"
    sleep 3

    # 1
    echo ""
    echo -e "  ${B}[1/7]${N} ${W}🔍  Checking Environment...${N}"
    if [ ! -d "$PT_DIR" ]; then
        echo -e "  ${R}❌  Pterodactyl directory not found!${N}"; return
    fi
    echo -e "  ${G}✔   Pterodactyl found.${N}"

    # 2
    echo ""
    echo -e "  ${B}[2/7]${N} ${W}📦  Installing Dependencies...${N}"
    (apt update -y -q && apt install -y curl wget unzip ca-certificates git gnupg zip -q) &
    spinner "Installing system packages"
    echo -e "  ${G}✔   System packages ready.${N}"

    # 3
    echo ""
    echo -e "  ${B}[3/7]${N} ${W}🟢  Setting up Node.js 20 & Yarn...${N}"
    (
        mkdir -p /etc/apt/keyrings
        curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
        echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list
        apt update -y -q && apt install -y nodejs -q
        npm i -g yarn
    ) &
    spinner "Configuring Node.js environment"
    echo -e "  ${G}✔   Node environment ready.${N}"

    # 4
    echo ""
    echo -e "  ${B}[4/7]${N} ${W}⬇️   Downloading Blueprint Framework...${N}"
    cd "$PT_DIR"
    DOWNLOAD_URL=$(curl -s https://api.github.com/repos/BlueprintFramework/framework/releases/latest | grep 'browser_download_url' | grep 'release.zip' | cut -d '"' -f 4)
    (wget -q "$DOWNLOAD_URL" -O "$PT_DIR/release.zip" && unzip -o -q release.zip) &
    spinner "Downloading & extracting Blueprint"
    echo -e "  ${G}✔   Files extracted.${N}"

    # 5
    echo ""
    echo -e "  ${B}[5/7]${N} ${W}⚙️   Configuring Blueprint...${N}"
    cat > "$PT_DIR/.blueprintrc" << 'BPRC'
WEBUSER="www-data";
OWNERSHIP="www-data:www-data";
USERSHELL="/bin/bash";
BPRC
    chmod +x "$PT_DIR/blueprint.sh"
    echo -e "  ${G}✔   Configuration applied.${N}"

    # 6
    echo ""
    echo -e "  ${B}[6/7]${N} ${W}🚀  Running Internal Installer...${N}"
    bash "$PT_DIR/blueprint.sh"

    # 7
    echo ""
    echo -e "  ${B}[7/7]${N} ${W}🛠️   Running Auto-Fix Diagnostics...${N}"
    (
        chown -R www-data:www-data "$PT_DIR"
        find "$PT_DIR" -type d -exec chmod 755 {} \;
        find "$PT_DIR" -type f -exec chmod 644 {} \;
        chmod +x "$PT_DIR/artisan" "$PT_DIR/blueprint.sh" 2>/dev/null
        yarn install --production --silent
        php artisan view:clear && php artisan config:clear && php artisan route:clear
    ) &
    spinner "Fixing permissions & clearing cache"

    echo ""
    divider
    echo -e "  ${G}${BOLD}🎉  COMPLETED SUCCESSFULLY!${N}"
    echo -e "  ${W}   Blueprint installed · Permissions fixed · Cache cleared${N}"
    divider
}

