# ══════════════════════════════════════════════════════════
#  LIVE STATUS FUNCTIONS
# ══════════════════════════════════════════════════════════
get_cpu() {
    local a b ta=0 tb=0
    read -ra a < /proc/stat
    sleep 0.1
    read -ra b < /proc/stat
    local v
    for v in "${a[@]:1}"; do (( ta += v )); done
    for v in "${b[@]:1}"; do (( tb += v )); done
    local dt di
    dt=$(( tb - ta ))
    di=$(( b[4] - a[4] ))
    (( dt > 0 )) && echo $(( (dt - di) * 100 / dt )) || echo 0
}

get_ram() {
    awk '/^MemTotal/{t=$2} /^MemAvailable/{a=$2} END{printf "%.0f",(t-a)/t*100}' /proc/meminfo 2>/dev/null || echo 0
}

get_net() {
    local iface state
    for iface in /sys/class/net/*; do
        [[ "$(basename "$iface")" == "lo" ]] && continue
        state=$(< "$iface/operstate" 2>/dev/null) || continue
        if [[ "$state" == "up" ]]; then
            echo "ONLINE"; return
        fi
    done
    echo "CONNECTED"
}

get_proxmox_status() {
    if ! command -v docker &>/dev/null 2>&1; then
        echo "${DM}○ DOCKER NOT FOUND${N}"; return
    fi
    if ! docker inspect proxmoxve &>/dev/null 2>&1; then
        echo "${DM}○ NOT DEPLOYED${N}"; return
    fi
    local st
    st=$(docker inspect -f '{{.State.Status}}' proxmoxve 2>/dev/null)
    case "$st" in
        running) echo "${GR}${BD}● RUNNING${N}" ;;
        exited)  echo "${YE}${BD}○ STOPPED${N}" ;;
        *)       echo "${DM}○ ${st^^}${N}" ;;
    esac
}

# ══════════════════════════════════════════════════════════
#  SYSTEM HEALTH BAR
# ══════════════════════════════════════════════════════════
sys_health() {
    local cpu ram net
    cpu=$(get_cpu)
    ram=$(get_ram)
    net=$(get_net)

    local cpu_c="${GR}" ram_c="${GR}" net_c="${GR}"
    (( cpu > 79 )) && cpu_c="${RE}" || (( cpu > 49 )) && cpu_c="${YE}"
    (( ram > 79 )) && ram_c="${RE}" || (( ram > 49 )) && ram_c="${YE}"
    [[ "$net" == "OFFLINE" ]] && net_c="${RE}"

    echo -e "  ${BD}${WH}System Health:${N}"
    echo -e "  CPU: ${cpu_c}${BD}${cpu}%${N}   RAM: ${ram_c}${BD}${ram}%${N}   Network: ${net_c}${BD}${net}${N}"
}

# ══════════════════════════════════════════════════════════
#  UI HELPERS
# ══════════════════════════════════════════════════════════
spinner() {
    local msg="$1" pid=$! i=0
    local f=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${PU}${f[$i]}${N}  %s" "$msg"
        i=$(( (i+1) % 8 )); sleep 0.08
    done
    printf "\r  ${GR}✔${N}  %s\n" "$msg"
}

typewriter() {
    local text="$1" color="${2:-$WH}"
    printf "%s" "$color"
    for ((i=0;i<${#text};i++)); do printf "%s" "${text:$i:1}"; sleep 0.015; done
    printf "%s\n" "$N"
}

progress_bar() {
    local lbl="${1:-Working}"
    printf "\n  ${CY}%s${N}\n  ${DM}[${N}" "$lbl"
    for ((i=0;i<35;i++)); do printf "${GR}█${N}"; sleep 0.02; done
    printf "${DM}]${N}  ${GR}Done!${N}\n\n"
}

