spinner() {
    local msg="$1"
    local pid=$!
    local i=0
    local -a f=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local -a c=("${R1}" "${R3}" "${R4}" "${R6}" "${R7}" "${R8}" "${R9}" "${R0}")
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${c[$i]}${f[$i]}${N}  %s" "$msg"
        i=$(( (i+1) % 8 )); sleep 0.08
    done
    printf "\r  ${GR}${BD}✔${N}  %s\n" "$msg"
}
 
typewriter() {
    local text="$1" color="${2:-$WH}"
