# ══════════════════════════════════════════════════════════
spinner() {
    local msg="$1"
    local pid=$!
    local i=0
    local -a f=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CY}${f[$i]}${N}  ${WH}%s${N}" "$msg"
        i=$(( (i+1) % 8 )); sleep 0.06
    done
    printf "\r  ${GR}${BD}✔${N}  ${WH}%s${N}\n" "$msg"
}
 
typewriter() {
    local text="$1" color="${2:-$WH}"
    printf "%s" "$color"
    for (( i=0; i<${#text}; i++ )); do printf "%s" "${text:$i:1}"; sleep 0.012; done
    printf "%s\n" "$N"
}
 
progress_bar() {
    local lbl="${1:-Working}" width=40
    printf "\n  ${CY}${BD}%s${N}\n  " "$lbl"
    echo -ne "${BK}["
    for (( i=0; i<width; i++ )); do
        local pct=$(( (i+1) * 100 / width ))
        if   (( pct < 40 )); then echo -ne "${RE}█${N}"
        elif (( pct < 75 )); then echo -ne "${YE}█${N}"
        else                       echo -ne "${GR}█${N}"
        fi
        sleep 0.018
    done
    echo -e "${BK}]${N}  ${GR}${BD}Done!${N}\n"
}
 
div()  {
    echo -e "  ${BK}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${N}"
}
tdiv() {
    echo -e "  ${BK}┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${N}"
}
 
section() {
    local title="$1"
    echo ""
    echo -e "  ${CY}╔══════════════════════════════════════════════════════════════╗${N}"
    printf  "  ${CY}║${N}  ${BD}${WH}%-60s${N}  ${CY}║${N}\n" "$title"
    echo -e "  ${CY}╚══════════════════════════════════════════════════════════════╝${N}"
    echo ""
}
 
sub_header() {
    clear; pixel_title
    local now
    now=$(date '+%H:%M:%S')
    echo -e "  ${PU}╔══════════════════════════════════════════════════════════════╗${N}"
    printf  "  ${PU}║${N}  ${BL}${PU}💎${N}  ${BD}${WH}ProXLegendYT${N}  ${BK}│${N}  ${CY}NODE ${VERSION}${N}  ${BK}│${N}  ${GR}● ONLINE${N}  ${BK}│${N}  ${DM}%s${N}  ${PU}║${N}\n" "$now"
    echo -e "  ${PU}╚══════════════════════════════════════════════════════════════╝${N}"
    echo ""
}
 
badge() {
    local label="$1" color="${2:-$CY}"
    printf "  ${color}${BD}[ %s ]${N}\n" "$label"
}
 
pause() {
    echo ""; tdiv
    printf "  ${BK}↩${N}  ${WH}Press ${YE}[Enter]${WH} to return...${N} "
    read -r _
}
 
confirm() {
    printf "  ${RE}${BD}⚠  Type '${WH}yes${RE}' to confirm: ${N}"
    read -r _confirm
    [[ "$_confirm" == "yes" ]]
}
 
