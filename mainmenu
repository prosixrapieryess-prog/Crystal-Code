# ══════════════════════════════════════════════
#   SYSTEM STATS
# ══════════════════════════════════════════════
get_cpu() {
    # Returns integer CPU usage %
    local cpu
    cpu=$(top -bn1 2>/dev/null | grep -i "cpu(s)\|Cpu" | head -1 | awk '{
        for(i=1;i<=NF;i++) if($i ~ /^[0-9.]+$/ && $(i+1) ~ /us/) { printf "%.0f", $i; exit }
    }')
    # fallback via /proc/stat
    if [[ -z "$cpu" ]]; then
        local line1 line2
        read -r line1 < /proc/stat
        sleep 0.2
        read -r line2 < /proc/stat
        local arr1=($line1) arr2=($line2)
        local idle1=$((arr1[4])) idle2=$((arr2[4]))
        local total1=0 total2=0
        for v in "${arr1[@]:1}"; do (( total1+=v )); done
        for v in "${arr2[@]:1}"; do (( total2+=v )); done
        local dtotal=$(( total2 - total1 )) didle=$(( idle2 - idle1 ))
        if (( dtotal > 0 )); then
            cpu=$(( (dtotal - didle) * 100 / dtotal ))
        else
            cpu=0
        fi
    fi
    echo "${cpu:-0}"
}

get_ram() {
    free 2>/dev/null | awk '/^Mem:/ {printf "%.0f", $3/$2*100}'
}

get_net() {
    if ping -c1 -W1 8.8.8.8 &>/dev/null 2>&1; then
        echo "CONNECTED"
    else
        echo "OFFLINE"
    fi
}

