# ══════════════════════════════════════════════════════════
#  SYSTEM HEALTH
# ══════════════════════════════════════════════════════════
sys_health() {
    local cpu=0 ram=0
    if [[ -r /proc/stat ]]; then
        local a=() b=()
        read -ra a < /proc/stat; sleep 0.15; read -ra b < /proc/stat
        local ta=0 tb=0
        for v in "${a[@]:1}"; do (( ta+=v )); done
        for v in "${b[@]:1}"; do (( tb+=v )); done
        local dt=$(( tb - ta )) di=$(( b[4] - a[4] ))
        (( dt > 0 )) && cpu=$(( (dt - di) * 100 / dt )) || cpu=0
    fi
    ram=$(free 2>/dev/null | awk '/^Mem:/{printf "%.0f",$3/$2*100}'); ram="${ram:-0}"

    local net_col="${GR}" net_txt="CONNECTED"
    ping -c1 -W1 8.8.8.8 &>/dev/null 2>&1 || { net_col="${RE}"; net_txt="OFFLINE"; }

    local cpu_c="${GR}" ram_c="${GR}"
    (( cpu > 79 )) && cpu_c="${RE}" || (( cpu > 49 )) && cpu_c="${YE}"
    (( ram > 79 )) && ram_c="${RE}" || (( ram > 49 )) && ram_c="${YE}"

    echo -e "  ${BD}${WH}System Health:${N}"
    echo -e "  CPU: ${cpu_c}${BD}${cpu}%${N}   RAM: ${ram_c}${BD}${ram}%${N}   Network: ${net_col}${BD}${net_txt}${N}"
}

