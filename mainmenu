# ══════════════════════════════════════════════════════════
#  LIVE STATUS FUNCTIONS
# ══════════════════════════════════════════════════════════
get_cpu() {
    local -a a b
    local ta=0 tb=0 dt di v
    read -ra a < /proc/stat
    sleep 0.1
    read -ra b < /proc/stat
    for v in "${a[@]:1}"; do (( ta += v )) || true; done
    for v in "${b[@]:1}"; do (( tb += v )) || true; done
    dt=$(( tb - ta ))
    di=$(( b[4] - a[4] ))
    (( dt > 0 )) && echo $(( (dt - di) * 100 / dt )) || echo 0
}
 
get_ram() {
    awk '/^MemTotal/{t=$2} /^MemAvailable/{a=$2} END{printf "%.0f",(t-a)/t*100}' \
        /proc/meminfo 2>/dev/null || echo 0
}
 
get_net() {
    local iface state
    for iface in /sys/class/net/*; do
        [[ "$(basename "$iface")" == "lo" ]] && continue
        state=$(< "$iface/operstate" 2>/dev/null) || continue
        if [[ "$state" == "up" ]]; then echo "ONLINE"; return; fi
    done
    echo "OFFLINE"
}
 
get_uptime() {
    local secs mins hrs
    secs=$(awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0)
    hrs=$(( secs / 3600 ))
    mins=$(( (secs % 3600) / 60 ))
    printf "%dh %dm" "$hrs" "$mins"
}
 
get_proxmox_status() {
    if ! command -v docker &>/dev/null; then
        echo "${DM}○ DOCKER NOT FOUND${N}"; return
    fi
    if ! docker inspect proxmoxve &>/dev/null 2>&1; then
        echo "${DM}○ NOT DEPLOYED${N}"; return
    fi
    local st
    st=$(docker inspect -f '{{.State.Status}}' proxmoxve 2>/dev/null)
    case "$st" in
        running) echo "${GR}${BD}● RUNNING${N}" ;;
        exited)  echo "${YE}${BD}○ STOPPED${N}" ;;
        *)       echo "${DM}○ ${st^^}${N}" ;;
    esac
}
 
# ══════════════════════════════════════════════════════════
#  SYSTEM HEALTH DASHBOARD
# ══════════════════════════════════════════════════════════
sys_health() {
    local cpu ram net upt
    cpu=$(get_cpu)
    ram=$(get_ram)
    net=$(get_net)
    upt=$(get_uptime)
 
    local cpu_c="${GR}" ram_c="${GR}" net_c="${GR}" net_ic="●"
    (( cpu > 79 )) && cpu_c="${RE}" || (( cpu > 49 )) && cpu_c="${YE}" || true
    (( ram > 79 )) && ram_c="${RE}" || (( ram > 49 )) && ram_c="${YE}" || true
    [[ "$net" == "OFFLINE" ]] && { net_c="${RE}"; net_ic="○"; }
 
    # Mini gauge bars
    local cpu_bar="" ram_bar=""
    local cpu_fill=$(( cpu * 20 / 100 )) ram_fill=$(( ram * 20 / 100 ))
    for (( i=0; i<20; i++ )); do
        if (( i < cpu_fill )); then cpu_bar+="${cpu_c}█${N}"; else cpu_bar+="${BK}░${N}"; fi
        if (( i < ram_fill )); then ram_bar+="${ram_c}█${N}"; else ram_bar+="${BK}░${N}"; fi
    done
 
    echo -e "  ${BK}╔══════════════════════════════════════════════════════════════╗${N}"
    echo -e "  ${BK}║${N}  ${BD}${WH}SYSTEM HEALTH                              ${DM}uptime: ${upt}${N}  ${BK}║${N}"
    echo -e "  ${BK}╠══════════════════════════════════════════════════════════════╣${N}"
    printf  "  ${BK}║${N}  CPU  ${cpu_bar}  ${cpu_c}${BD}%3d%%${N}  ${BK}║${N}\n" "$cpu"
    printf  "  ${BK}║${N}  RAM  ${ram_bar}  ${ram_c}${BD}%3d%%${N}  ${BK}║${N}\n" "$ram"
    printf  "  ${BK}║${N}  NET  ${net_c}${BD}${net_ic} %-10s${N}                               ${BK}║${N}\n" "$net"
    echo -e "  ${BK}╚══════════════════════════════════════════════════════════════╝${N}"
}
 
