idx_setup_menu() {
    sub_header
    section "💎  IDX WORKSPACE SETUP"

    local repo_root
    repo_root="$(_find_repo_root)"
    local nix_file="$repo_root/.idx/dev.nix"

    echo -e "  ${DM}Repo root detected :${N} ${WH}${repo_root}${N}"
