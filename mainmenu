intro() {
    clear; echo ""

    local brand="ProXLegendYT — BOOTING NODE..."
    local chars='@#$%!?*^~'
    for run in 1 2 3 4 5; do
        local glitch=""
        for ((i=0; i<${#brand}; i++)); do
            (( RANDOM % 3 == 0 )) \
                && glitch+="${chars:$((RANDOM % ${#chars})):1}" \
                || glitch+="${brand:$i:1}"
        done
        printf "\r  ${PU}${BD}%s${N}" "$glitch"; sleep 0.08
    done
    printf "\r  ${PU}${BD}%s${N}\n\n" "$brand"

    pixel_title
    typewriter "  💎  ProXLegendYT — Initializing system..." "$PU"
    sleep 0.3
    progress_bar "🔧  Loading ProXLegendYT NODE"
    typewriter "  🌐  Establishing secure connection..." "$CY"
    sleep 0.2
    typewriter "  🛡️   Security modules loaded." "$GR"
    sleep 0.2
    typewriter "  🚀  All systems online!" "$YE"
    sleep 0.4
    fireworks
    sleep 0.5
}

