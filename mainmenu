# ══════════════════════════════════════════════════════════════
#  LIVE STATUS FUNCTIONS
# ══════════════════════════════════════════════════════════════
get_cpu() {
    local -a a b
    local ta=0 tb=0 dt di v
    read -ra a < /proc/stat
    sleep 0.1
    read -ra b < /proc/stat
    for v in "${a[@]:1}"; do (( ta += v )) || true; done
    for v in "${b[@]:1}"; do (( tb += v )) || true; done
    dt=$(( tb - ta ))
    di=$(( b[4] - a[4] ))
    (( dt > 0 )) && echo $(( (dt - di) * 100 / dt )) || echo 0
}
 
get_ram() {
    awk '/^MemTotal/{t=$2} /^MemAvailable/{a=$2} END{printf "%.0f",(t-a)/t*100}' \
        /proc/meminfo 2>/dev/null || echo 0
}
 
get_net() {
    local iface state
    for iface in /sys/class/net/*; do
        [[ "$(basename "$iface")" == "lo" ]] && continue
        state=$(< "$iface/operstate" 2>/dev/null) || continue
        [[ "$state" == "up" ]] && { echo "CONNECTED"; return; }
    done
    echo "CONNECTED"
}
 
get_proxmox_status() {
    if ! command -v docker &>/dev/null; then
        echo "${DM}○ DOCKER NOT FOUND${N}"; return
    fi
    if ! docker inspect proxmoxve &>/dev/null; then
        echo "${DM}○ NOT DEPLOYED${N}"; return
    fi
    local st
    st=$(docker inspect -f '{{.State.Status}}' proxmoxve 2>/dev/null)
    case "$st" in
        running) echo "${GR}${BD}● RUNNING${N}" ;;
        exited)  echo "${YE}${BD}○ STOPPED${N}" ;;
        *)       echo "${DM}○ ${st^^}${N}" ;;
    esac
}
 
# ══════════════════════════════════════════════════════════════
#  SYSTEM HEALTH BAR  (rainbow gradient, no dotted look)
# ══════════════════════════════════════════════════════════════
 
# Dark gray for empty bar segments — visible but clearly "empty"
EB=$'\033[38;5;237m'
 
draw_bar() {
    local pct=$1
    # Color stops: low=green, mid=yellow, high=red  (256-color gradient)
    local -a LOW=(46 82 118 154 148 142)
    local -a MID=(214 208 202 196 196 196)
    local total=25
    local filled=$(( pct * total / 100 ))
    (( filled < 1 && pct > 0 )) && filled=1
 
    printf "\033[38;5;240m▕\033[0m"
    local ci=0
    for (( i=0; i<total; i++ )); do
        if (( i < filled )); then
            # Pick color from gradient based on position
            local seg=$(( i * 10 / total ))   # 0-9
            local col
            if (( pct <= 50 )); then
                col=${LOW[$((seg % 6))]}
            elif (( pct <= 79 )); then
                col=${MID[$((seg % 6))]}
            else
                col=196  # all red
            fi
            printf "\033[1;38;5;%dm█\033[0m" "$col"
        else
            printf "%s·%s" "$EB" "$N"
        fi
    done
    printf "\033[38;5;240m▏\033[0m"
}
 
