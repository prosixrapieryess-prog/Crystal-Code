        tdiv
        echo -e "  ${YE}  1${N}  ${DM}│${N}  🔄  ${WH}Overwrite & regenerate dev.nix${N}"
        tdiv
        echo -e "  ${CY}  2${N}  ${DM}│${N}  👁   ${WH}View current dev.nix${N}"
