                progress_bar "📦  Fetching installer"
                bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/install.sh)
                pause ;;
            2)
                sub_header; section "👤  Create Panel User"
                if [[ -d /var/www/pterodactyl ]]; then
                    cd /var/www/pterodactyl && php artisan p:user:make
                else
                    echo -e "  ${RE}❌  Panel not installed!${N}"
                fi
                pause ;;
            3)
                sub_header; section "🔄  Updating Panel..."
                if [[ ! -d /var/www/pterodactyl ]]; then
                    echo -e "  ${RE}❌  Panel not found!${N}"; sleep 2; continue
                fi
                progress_bar "⬇️   Downloading latest release"
                cd /var/www/pterodactyl
                php artisan down
                curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
                tar -xzvf panel.tar.gz
                COMPOSER_ALLOW_SUPERUSER=1 composer install --no-dev --optimize-autoloader
                php artisan migrate --seed --force
                php artisan up
                echo -e "\n  ${GR}✔  Panel updated!${N}"
                pause ;;
            4)
                sub_header; section "🔒  SSL Certificate"
                progress_bar "🔐  Setting up SSL"
                bash <(curl -fsSL https://raw.githubusercontent.com/nobita329/ptero/main/ptero/panel/pterodactyl/ssl.sh)
                pause ;;
            5)
                sub_header; section "🗑️   Uninstall Panel"
                echo -e "  ${RE}${BD}⚠️   Permanently deletes the panel!${N}"
                printf "  ${RE}Type 'yes' to confirm: ${N}"; read -r conf
                if [[ "$conf" == "yes" ]]; then
                    progress_bar "🗑️   Removing"
                    rm -rf /var/www/pterodactyl
                    echo -e "  ${GR}✔  Panel removed.${N}"
                else
                    echo -e "  ${CY}Cancelled.${N}"
                fi
                sleep 2 ;;
            0) break ;;
            *) echo -e "\n  ${RE}Invalid option.${N}"; sleep 1 ;;
        esac
    done
}

# ══════════════════════════════════════════════════════════
#  [5]  BLUEPRINT
# ══════════════════════════════════════════════════════════
blueprint_menu() {
    sub_header
    section "🔷  BLUEPRINT v3.0 — AUTO INSTALL & FIX"
    local PT_DIR="/var/www/pterodactyl"

    if [[ "$EUID" -ne 0 ]]; then
        echo -e "  ${RE}❌  Run as root!${N}"; pause; return
    fi
    if [[ ! -d "$PT_DIR" ]]; then
        echo -e "  ${RE}❌  Pterodactyl not found at $PT_DIR${N}"; pause; return
    fi

    echo -e "  ${YE}⚠️   Target: ${CY}$PT_DIR${N}"
    typewriter "  ⏳  Starting in 3 seconds..." "$WH"
    sleep 3

    echo -e "\n  ${CY}[1/7]${N} ${WH}Checking environment...${N}"
    echo -e "  ${GR}✔   Pterodactyl found.${N}"

    echo -e "\n  ${CY}[2/7]${N} ${WH}Installing dependencies...${N}"
    (apt update -y -q && apt install -y curl wget unzip ca-certificates git gnupg zip -q) &
    spinner "Installing packages"

    echo -e "\n  ${CY}[3/7]${N} ${WH}Setting up Node.js 20 + Yarn...${N}"
    (
        mkdir -p /etc/apt/keyrings
        curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
            | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
        echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
            > /etc/apt/sources.list.d/nodesource.list
        apt update -y -q && apt install -y nodejs -q
        npm i -g yarn -q
    ) &
    spinner "Node.js + Yarn"

    echo -e "\n  ${CY}[4/7]${N} ${WH}Downloading Blueprint...${N}"
    (
        cd "$PT_DIR"
        local DL
        DL=$(curl -s https://api.github.com/repos/BlueprintFramework/framework/releases/latest \
            | grep 'browser_download_url' | grep 'release.zip' | cut -d'"' -f4)
        wget -q "$DL" -O release.zip && unzip -o -q release.zip
    ) &
    spinner "Downloading & extracting"

    echo -e "\n  ${CY}[5/7]${N} ${WH}Writing config...${N}"
    printf 'WEBUSER="www-data";\nOWNERSHIP="www-data:www-data";\nUSERSHELL="/bin/bash";\n' \
        > "$PT_DIR/.blueprintrc"
    chmod +x "$PT_DIR/blueprint.sh"
    echo -e "  ${GR}✔   Config applied.${N}"

    echo -e "\n  ${CY}[6/7]${N} ${WH}Running Blueprint installer...${N}"
    bash "$PT_DIR/blueprint.sh"

    echo -e "\n  ${CY}[7/7]${N} ${WH}Fixing permissions & clearing cache...${N}"
    (
        chown -R www-data:www-data "$PT_DIR"
        find "$PT_DIR" -type d -exec chmod 755 {} \;
        find "$PT_DIR" -type f -exec chmod 644 {} \;
        chmod +x "$PT_DIR/artisan" "$PT_DIR/blueprint.sh" 2>/dev/null
        yarn --cwd "$PT_DIR" install --production --silent
        php artisan view:clear && php artisan config:clear && php artisan route:clear
    ) &
    spinner "Permissions + cache"

    div
    echo -e "  ${GR}${BD}🎉  Blueprint installed successfully!${N}"
    div
    pause
}

